<style>
  :root{
    --bg:#0A0D1A;
    --surface:#12162C;
    --surface-2:#171C38;
    --line:#262C50;
    --cyan:#00E0FF;
    --magenta:#FF2D6A;
    --amber:#FFB627;
    --text:#E9ECFA;
    --text-dim:#8993B8;
    --text-faint:#545C82;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Inter',sans-serif;
    overflow-x:hidden;
  }
  body::before{
    content:'';
    position:fixed; inset:0;
    background:
      radial-gradient(ellipse 800px 500px at 15% -10%, rgba(255,45,106,0.10), transparent 60%),
      radial-gradient(ellipse 900px 600px at 100% 10%, rgba(0,224,255,0.08), transparent 60%);
    pointer-events:none;
    z-index:0;
  }
  #bgGrid{position:fixed; inset:0; z-index:0; opacity:0.55; pointer-events:none;}
  body::after{
    content:'';
    position:fixed; inset:0; z-index:1; pointer-events:none;
    background:repeating-linear-gradient(180deg, rgba(255,255,255,0.012) 0px, rgba(255,255,255,0.012) 1px, transparent 1px, transparent 3px);
    mix-blend-mode:overlay;
  }
  .hud{position:relative;}
  .hud::before, .hud::after{
    content:''; position:absolute; width:14px; height:14px;
    border-color:var(--cyan); pointer-events:none; z-index:2; opacity:0.7;
  }
  .hud::before{top:-1px; left:-1px; border-top:2px solid; border-left:2px solid;}
  .hud::after{bottom:-1px; right:-1px; border-bottom:2px solid; border-right:2px solid;}
  .hud.hud-magenta::before, .hud.hud-magenta::after{border-color:var(--magenta);}
  .hud.hud-amber::before, .hud.hud-amber::after{border-color:var(--amber);}

  .ticker-bar{
    background:#080A14; border-bottom:1px solid var(--line);
    overflow:hidden; white-space:nowrap; position:relative; height:30px; display:flex; align-items:center;
  }
  .ticker-bar .ticker-track{
    display:inline-flex; gap:48px; padding-left:100%;
    animation:ticker-scroll 28s linear infinite;
  }
  .ticker-bar span{
    font-family:'JetBrains Mono'; font-size:11px; color:var(--text-faint); letter-spacing:0.03em;
  }
  .ticker-bar span b{color:var(--cyan); font-weight:500;}
  @keyframes ticker-scroll{
    0%{transform:translateX(0);}
    100%{transform:translateX(-100%);}
  }
  .wrap{max-width:1180px; margin:0 auto; padding:0 28px; position:relative; z-index:1;}
  h1,h2,h3{font-family:'Space Grotesk',sans-serif; letter-spacing:-0.01em;}
  .mono{font-family:'JetBrains Mono',monospace;}

  nav{
    position:sticky; top:0; z-index:50;
    background:rgba(10,13,26,0.78);
    backdrop-filter:blur(14px);
    border-bottom:1px solid var(--line);
  }
  nav .wrap{display:flex; align-items:center; justify-content:space-between; height:68px;}
  .logo{display:flex; align-items:center; gap:9px; font-family:'Space Grotesk'; font-weight:700; font-size:18px;}
  .logo-mark{
    width:26px; height:26px; border-radius:7px;
    background:linear-gradient(135deg, var(--cyan), var(--magenta));
    display:flex; align-items:center; justify-content:center;
    font-size:13px; font-weight:700; color:#0A0D1A;
  }
  .nav-links{display:flex; gap:32px; font-size:14px; color:var(--text-dim);}
  .nav-links a{color:inherit; text-decoration:none; transition:color .2s;}
  .nav-links a:hover{color:var(--text);}
  .nav-cta{
    background:var(--text); color:var(--bg); font-weight:600; font-size:14px;
    padding:9px 18px; border-radius:7px; text-decoration:none;
    transition:transform .15s ease;
  }
  .nav-cta:hover{transform:translateY(-1px);}

  .hero{padding:84px 0 60px; text-align:center;}
  .eyebrow{
    display:inline-flex; align-items:center; gap:8px;
    font-family:'JetBrains Mono'; font-size:12px; letter-spacing:0.06em;
    color:var(--cyan); background:rgba(0,224,255,0.08);
    border:1px solid rgba(0,224,255,0.25); padding:6px 14px; border-radius:100px;
    margin-bottom:28px;
  }
  .eyebrow .dot{width:6px; height:6px; border-radius:50%; background:var(--cyan); animation:pulse-dot 1.6s infinite;}
  @keyframes pulse-dot{0%,100%{opacity:1;}50%{opacity:0.3;}}
  .hero h1{
    font-size:clamp(36px,6vw,68px); line-height:1.04; font-weight:700;
    max-width:880px; margin:0 auto 22px;
  }
  .hero h1 .grad{
    background:linear-gradient(90deg, var(--cyan), var(--magenta));
    -webkit-background-clip:text; background-clip:text; color:transparent;
  }
  .hero p.sub{
    font-size:17px; color:var(--text-dim); max-width:640px; margin:0 auto 26px; line-height:1.7;
  }
  .hero p.sub-2{
    font-size:14px; color:var(--text-faint); max-width:560px; margin:0 auto 32px; line-height:1.6;
  }

  .studio{
    max-width:920px; margin:0 auto;
    background:linear-gradient(180deg, var(--surface), var(--surface-2));
    border:1px solid var(--line); border-radius:18px;
    padding:26px; text-align:left;
    box-shadow:0 30px 80px -30px rgba(0,0,0,0.7), 0 0 0 1px rgba(0,224,255,0.04), 0 0 60px -15px rgba(255,45,106,0.12);
    position:relative;
  }
  .blink-cursor{display:inline-block; width:8px; height:16px; background:var(--cyan); margin-left:2px; animation:blink 1s step-end infinite; vertical-align:middle;}
  @keyframes blink{50%{opacity:0;}}
  .studio-bar{display:flex; align-items:center; gap:10px; margin-bottom:18px;}
  .studio-bar .dots{display:flex; gap:6px;}
  .studio-bar .dots span{width:9px; height:9px; border-radius:50%; background:var(--line);}
  .studio-bar .label{font-family:'JetBrains Mono'; font-size:12px; color:var(--text-faint); margin-left:auto;}

  .input-row{display:flex; gap:10px; margin-bottom:22px;}
  .input-row input{
    flex:1; background:var(--bg); border:1px solid var(--line); border-radius:10px;
    padding:14px 16px; color:var(--text); font-family:'Inter'; font-size:14.5px; outline:none;
    transition:border-color .2s;
  }
  .input-row input:focus{border-color:var(--cyan);}
  .input-row input::placeholder{color:var(--text-faint);}
  .gen-btn{
    background:linear-gradient(90deg, var(--cyan), var(--magenta));
    color:#0A0D1A; font-weight:700; font-family:'Space Grotesk'; font-size:14px;
    border:none; border-radius:10px; padding:0 24px; cursor:pointer;
    white-space:nowrap; transition:opacity .2s, transform .15s;
  }
  .gen-btn:hover{opacity:0.92; transform:translateY(-1px);}
  .gen-btn:disabled{opacity:0.5; cursor:wait;}

  .lanes{display:flex; flex-direction:column; gap:10px;}
  .lane{
    display:grid; grid-template-columns:96px 1fr 110px; align-items:center; gap:14px;
    background:var(--bg); border:1px solid var(--line); border-radius:10px;
    padding:13px 16px; min-height:54px;
  }
  .lane-name{font-family:'JetBrains Mono'; font-size:11.5px; color:var(--text-dim); display:flex; align-items:center; gap:7px;}
  .lane-name .swatch{width:7px; height:7px; border-radius:50%;}
  .lane[data-model="cyan"] .lane-name .swatch{background:var(--cyan);}
  .lane[data-model="magenta"] .lane-name .swatch{background:var(--magenta);}
  .lane[data-model="amber"] .lane-name .swatch{background:var(--amber);}
  .lane canvas{width:100%; height:30px; display:block;}
  .lane-status{font-family:'JetBrains Mono'; font-size:11px; color:var(--text-faint); text-align:right;}
  .lane.done .lane-status{color:var(--text-dim);}
  .lane-output{
    grid-column:1 / -1; font-size:13.5px; color:var(--text); line-height:1.5;
    max-height:0; opacity:0; overflow:hidden; transition:max-height .4s ease, opacity .4s ease, margin .4s ease;
    border-top:1px solid var(--line); padding-top:0;
  }
  .lane.revealed .lane-output{max-height:80px; opacity:1; margin-top:10px; padding-top:10px;}

  .trust{padding:50px 0; border-top:1px solid var(--line); border-bottom:1px solid var(--line);}
  .trust .wrap{display:flex; justify-content:space-between; flex-wrap:wrap; gap:24px;}
  .trust-item{flex:1; min-width:160px; text-align:center;}
  .trust-item .num{font-family:'Space Grotesk'; font-size:30px; font-weight:700;}
  .trust-item .lab{font-size:12.5px; color:var(--text-faint); margin-top:4px; font-family:'JetBrains Mono';}

  .section{padding:96px 0;}
  .section-head{max-width:560px; margin-bottom:56px;}
  .section-head .kicker{font-family:'JetBrains Mono'; font-size:12px; color:var(--magenta); letter-spacing:0.06em; margin-bottom:14px; display:block;}
  .section-head h2{font-size:clamp(26px,3.4vw,38px); font-weight:600; line-height:1.18;}
  .section-head p{font-size:14px; color:var(--text-dim); margin-top:14px; line-height:1.7;}

  .models-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:20px;}
  .model-card{
    background:var(--surface); border:1px solid var(--line); border-radius:16px;
    padding:28px; position:relative; overflow:hidden;
    transition:border-color .25s, transform .25s, box-shadow .25s;
  }
  .model-card:hover{transform:translateY(-3px); border-color:var(--line);}
  .model-card[data-m="1"]:hover{box-shadow:0 0 0 1px rgba(0,224,255,0.3), 0 20px 50px -25px rgba(0,224,255,0.25);}
  .model-card[data-m="2"]:hover{box-shadow:0 0 0 1px rgba(255,45,106,0.3), 0 20px 50px -25px rgba(255,45,106,0.25);}
  .model-card[data-m="3"]:hover{box-shadow:0 0 0 1px rgba(255,182,39,0.3), 0 20px 50px -25px rgba(255,182,39,0.25);}
  .model-card::before{
    content:''; position:absolute; top:0; left:0; right:0; height:2px;
  }
  .model-card[data-m="1"]::before{background:var(--cyan);}
  .model-card[data-m="2"]::before{background:var(--magenta);}
  .model-card[data-m="3"]::before{background:var(--amber);}
  .model-card .tag{font-family:'JetBrains Mono'; font-size:11px; color:var(--text-faint); margin-bottom:14px;}
  .model-card h3{font-size:19px; margin-bottom:10px;}
  .model-card p{font-size:14px; color:var(--text-dim); line-height:1.6;}
  .model-card .stat{
    margin-top:20px; padding-top:18px; border-top:1px solid var(--line);
    display:flex; justify-content:space-between; font-family:'JetBrains Mono'; font-size:12px;
  }
  .model-card .stat b{color:var(--text); font-size:15px; font-family:'Space Grotesk';}

  .platforms{padding:60px 0; text-align:center;}
  .platforms p{font-family:'JetBrains Mono'; font-size:12px; color:var(--text-faint); margin-bottom:24px; letter-spacing:0.06em;}
  .plat-list{display:flex; justify-content:center; gap:36px; flex-wrap:wrap; font-family:'Space Grotesk'; font-weight:600; font-size:16px; color:var(--text-dim);}

  .compare{padding:96px 0;}
  table{width:100%; border-collapse:collapse; background:var(--surface); border-radius:14px; overflow:hidden; border:1px solid var(--line);}
  th,td{padding:16px 22px; text-align:left; font-size:14px; border-bottom:1px solid var(--line);}
  th{font-family:'JetBrains Mono'; font-size:11.5px; color:var(--text-faint); font-weight:500; text-transform:uppercase; letter-spacing:0.04em;}
  td.metric{color:var(--text-dim); font-family:'JetBrains Mono'; font-size:13px;}
  td.win{color:var(--cyan); font-family:'Space Grotesk'; font-weight:600;}
  tr:last-child td{border-bottom:none;}

  .pricing{padding:96px 0; text-align:center;}
  .price-card{
    max-width:420px; margin:0 auto; background:linear-gradient(180deg, var(--surface), var(--surface-2));
    border:1px solid var(--amber); border-radius:18px; padding:40px;
    box-shadow:0 0 60px -20px rgba(255,182,39,0.18);
  }
  .price-card .badge{
    display:inline-block; font-family:'JetBrains Mono'; font-size:11px; color:var(--amber);
    background:rgba(255,182,39,0.1); border:1px solid rgba(255,182,39,0.3);
    padding:5px 12px; border-radius:100px; margin-bottom:20px;
  }
  .price-card .amount{font-family:'Space Grotesk'; font-size:52px; font-weight:700;}
  .price-card .amount span{font-size:16px; color:var(--text-faint); font-weight:400;}
  .price-card ul{list-style:none; text-align:left; margin:28px 0; display:flex; flex-direction:column; gap:12px;}
  .price-card li{font-size:14px; color:var(--text-dim); display:flex; gap:10px; align-items:flex-start;}
  .price-card li::before{content:'—'; color:var(--amber); flex-shrink:0;}
  .price-cta{
    display:block; width:100%; padding:15px; border-radius:10px; border:none;
    background:linear-gradient(90deg, var(--cyan), var(--magenta)); color:#0A0D1A;
    font-family:'Space Grotesk'; font-weight:700; font-size:15px; cursor:pointer;
  }

  footer{padding:50px 0; border-top:1px solid var(--line); text-align:center; color:var(--text-faint); font-size:13px; font-family:'JetBrains Mono';}

  @media (max-width:760px){
    .models-grid{grid-template-columns:1fr;}
    .input-row{flex-direction:column;}
    .lane{grid-template-columns:1fr; gap:8px;}
    .lane-status{text-align:left;}
    .trust .wrap{justify-content:flex-start;}
  }
  @media (prefers-reduced-motion: reduce){
    *{animation:none !important; transition:none !important;}
  }
</style>
