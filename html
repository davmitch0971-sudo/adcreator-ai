const briefInput = document.getElementById('briefInput');
const genBtn = document.getElementById('genBtn');
const lanes = document.querySelectorAll('.lane');

const outputs = {
  cyan: (b) => `Performance‑optimized hook: “Don’t just moisturize. Restore.” — engineered for high‑intent feeds. Brief: ${b}`,
  magenta: (b) => `In a world that asks more of your skin every day, one ritual gives it back. A cinematic, brand‑first angle inspired by: ${b}`,
  amber: (b) => `New drop. Limited stock. Skin care that works as hard as you do. Built for rapid testing and scale. // Brief: ${b}`
};

function setupCanvas(canvas){
  const dpr = window.devicePixelRatio || 1;
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * dpr;
  canvas.height = rect.height * dpr;
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);
  return {ctx, w: rect.width, h: rect.height};
}

function drawIdleLine(canvas, color){
  const {ctx, w, h} = setupCanvas(canvas);
  ctx.clearRect(0,0,w,h);
  ctx.strokeStyle = color;
  ctx.globalAlpha = 0.25;
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(0, h/2);
  ctx.lineTo(w, h/2);
  ctx.stroke();
}

function animateWave(canvas, color, duration, seed){
  const {ctx, w, h} = setupCanvas(canvas);
  const start = performance.now();
  function frame(t){
    const elapsed = t - start;
    const progress = Math.min(elapsed / duration, 1);
    ctx.clearRect(0,0,w,h);
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.8;
    ctx.beginPath();
    const bars = 48;
    const revealed = Math.floor(bars * progress);
    for(let i=0;i<bars;i++){
      const x = (i/bars) * w;
      let amp;
      if(i < revealed){
        amp = (Math.sin(i*0.6 + seed) * 0.5 + Math.sin(i*1.3+seed*2)*0.3) * (h*0.42);
      } else if (i === revealed){
        amp = Math.sin(t*0.02 + seed) * (h*0.42);
      } else {
        amp = 0;
      }
      ctx.globalAlpha = i <= revealed ? 0.9 : 0.15;
      ctx.moveTo(x, h/2 - amp/2);
      ctx.lineTo(x, h/2 + amp/2);
    }
    ctx.stroke();
    if(progress < 1){
      requestAnimationFrame(frame);
    } else {
      drawIdleLine(canvas, color);
      ctx.globalAlpha=1;
    }
  }
  requestAnimationFrame(frame);
}

const colorMap = {cyan:'#00E0FF', magenta:'#FF2D6A', amber:'#FFB627'};

lanes.forEach(lane=>{
  const canvas = lane.querySelector('canvas');
  const model = lane.dataset.model;
  drawIdleLine(canvas, colorMap[model]);
});

function runGeneration(){
  const brief = briefInput.value.trim() || 'your product';
  genBtn.disabled = true;
  genBtn.textContent = 'Generating elite set…';

  lanes.forEach((lane, i)=>{
    lane.classList.remove('revealed','done');
    const status = lane.querySelector('.lane-status');
    const out = lane.querySelector('.lane-output');
    out.textContent = '';
    status.textContent = 'queued';
    const canvas = lane.querySelector('canvas');
    const model = lane.dataset.model;
    const delay = i * 220;
    const duration = 1400 + i*300;

    setTimeout(()=>{
      status.textContent = 'generating…';
      animateWave(canvas, colorMap[model], duration, i*1.7);
      setTimeout(()=>{
        status.textContent = 'complete';
        lane.classList.add('done');
        out.textContent = outputs[model](brief);
        lane.classList.add('revealed');
        if(i === lanes.length-1){
          genBtn.disabled = false;
          genBtn.textContent = 'Generate 3 elite versions';
        }
      }, duration);
    }, delay);
  });
}

genBtn.addEventListener('click', runGeneration);
window.addEventListener('resize', ()=>{
  lanes.forEach(lane=>{
    const canvas = lane.querySelector('canvas');
    const model = lane.dataset.model;
    if(!lane.classList.contains('revealed')) drawIdleLine(canvas, colorMap[model]);
  });
});

setTimeout(runGeneration, 600);

(function(){
  const canvas = document.getElementById('bgGrid');
  const ctx = canvas.getContext('2d');
  let w,h,nodes;
  const COLORS = ['#00E0FF','#FF2D6A','#FFB627'];

  function resize(){
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
  }
  function initNodes(){
    const count = Math.min(60, Math.floor((w*h)/28000));
    nodes = Array.from({length:count}, ()=>({
      x:Math.random()*w, y:Math.random()*h,
      vx:(Math.random()-0.5)*0.18, vy:(Math.random()-0.5)*0.18,
      c: COLORS[Math.floor(Math.random()*COLORS.length)]
    }));
  }
  function step(){
    ctx.clearRect(0,0,w,h);
    nodes.forEach(n=>{
      n.x += n.vx;
      n.y += n.vy;
      if(n.x<0||n.x>w) n.vx*=-1;
      if(n.y<0||n.y>h) n.vy*=-1;
      ctx.globalAlpha = 0.5;
      ctx.fillStyle = n.c;
      ctx.beginPath();
      ctx.arc(n.x,n.y,1.4,0,Math.PI*2);
      ctx.fill();
    });
    ctx.globalAlpha = 1;
    requestAnimationFrame(step);
  }
  resize(); initNodes();
  if(!window.matchMedia('(prefers-reduced-motion: reduce)').matches){
    requestAnimationFrame(step);
  }
  window.addEventListener('resize', ()=>{ resize(); initNodes(); });
})();

(function(){
  const targets = [
    {sel:'[data-count="models"]', end:3, suffix:''},
    {sel:'[data-count="time"]', end:11, suffix:'s'},
    {sel:'[data-count="platforms"]', end:8, suffix:''},
    {sel:'[data-count="ctr"]', end:12.5, suffix:'%', decimals:1}
  ];
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        targets.forEach(t=>{
          const el = document.querySelector(t.sel);
          if(!el) return;
          const dur = 1100, start = performance.now();
          function tick(now){
            const p = Math.min((now-start)/dur, 1);
            const val = t.end * p;
            el.textContent = (t.decimals ? val.toFixed(t.decimals) : Math.floor(val)) + t.suffix;
            if(p<1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });
        io.disconnect();
      }
    });
  }, {threshold:0.4});
  const trust = document.querySelector('.trust');
  if(trust) io.observe(trust);
})();
</script>

